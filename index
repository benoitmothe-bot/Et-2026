const mapCache = {};

function openModal(id) {
  const d = DESTS.find(x=>x.id===id);
  if(!d) return;
  document.getElementById('mHeroImg').src = d.heroImg;
  document.getElementById('mHeroImg').onerror = function(){this.src=FALLBACK};
  document.getElementById('mFlag').textContent = d.flag;
  document.getElementById('mName').textContent = d.name + ' — ' + d.sub;
  document.getElementById('mSub').textContent = d.tagline;
  document.getElementById('mCols').style.borderColor = d.color;
  document.getElementById('mTags').innerHTML =
    d.tags.map(t=>`<span class="mtag">${t}</span>`).join('') +
    `<span class="mtag">🌡️ ${d.climate}</span>` +
    (d.visited?`<span class="mtag" style="border-color:rgba(239,68,68,.5);color:rgba(239,68,68,.9)">🚫 Déjà visités tous les deux</span>`:'') +
    (d.marionVisited?`<span class="mtag" style="border-color:rgba(239,68,68,.5);color:rgba(239,68,68,.9)">⚠️ Déjà vu par Marion</span>`:'');
  document.getElementById('mWeeks').innerHTML = d.weeks.map(w=>`
    <div class="mweek">
      <div class="mwbadge" style="background:${d.color}">S${w.n}</div>
      <div class="mwbody"><h4>${w.place}</h4><p>${w.desc}</p></div>
    </div>`).join('');
  document.getElementById('mInfo').innerHTML = d.info.map(i=>`
    <div class="micard" style="border-color:${i.col}">
      <h5 style="color:${i.col}">${i.icon} ${i.title}</h5>
      <p>${i.c}</p>
    </div>`).join('');
  document.getElementById('mMapTitle').textContent = `🗺️ Road Trip — ${d.name}`;
  document.getElementById('mLegend').innerHTML = d.map.legend.map(l=>
    `<div class="leg"><div class="leg-dot" style="background:${l.c}"></div>${l.l}</div>`).join('');
  document.getElementById('mGallery').innerHTML = d.gallery.map(g=>
    `<img src="${g}" alt="${d.name}" onerror="this.src='${FALLBACK}'">`).join('');
  document.getElementById('modalBg').classList.add('open');
  document.body.style.overflow = 'hidden';
  setTimeout(()=>initMap(d), 200);
}

function initMap(d) {
  const el = document.getElementById('mMap');
  if(mapCache[d.id]) { mapCache[d.id].remove(); delete mapCache[d.id]; }
  el.innerHTML = '';
  const m = L.map('mMap',{scrollWheelZoom:false}).setView(d.map.center,d.map.zoom);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',{
    attribution:'© <a href="https://openstreetmap.org/copyright">OSM</a> © <a href="https://carto.com/">CARTO</a>',
    subdomains:'abcd',maxZoom:19
  }).addTo(m);
  d.map.routes.forEach(r=>{
    const o={color:r.color,weight:r.w||3,opacity:.9};
    if(r.dash) o.dashArray=r.dash;
    L.polyline(r.coords,o).addTo(m);
  });
  d.map.markers.forEach(mk=>{
    const txt = mk.l.length > 6 ? mk.l.substring(0,6)+'…' : mk.l;
    L.marker(mk.p,{icon:L.divIcon({
      html:`<div style="background:${mk.c};color:#fff;border-radius:50%;width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:7.5px;font-weight:700;font-family:Outfit,sans-serif;box-shadow:0 2px 8px rgba(0,0,0,.3);border:2.5px solid rgba(255,255,255,.9);text-align:center;line-height:1.1;padding:2px">${txt}</div>`,
      className:'',iconSize:[32,32],iconAnchor:[16,16]
    })}).addTo(m).bindPopup(`<b style="font-family:Outfit">${mk.l}</b>`);
  });
  mapCache[d.id]=m;
  setTimeout(()=>m.invalidateSize(),250);
}

