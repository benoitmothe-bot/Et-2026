document.getElementById('commentForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = this.querySelector('.cf-btn');
  btn.textContent = 'Envoi en cours...';
  btn.disabled = true;
  try {
    const res = await fetch(this.action, {
      method:'POST',
      body: new FormData(this),
      headers:{Accept:'application/json'}
    });
    if(res.ok){
      document.getElementById('cfSuccess').style.display='block';
      this.reset();
      btn.style.display='none';
    } else {
      btn.textContent = 'Erreur — réessayez';
      btn.disabled = false;
    }
  } catch(err){
    btn.textContent = 'Erreur réseau — réessayez';
    btn.disabled = false;
  }
});

// ── QUIZ ENGINE ──
const QUIZ_ANSWERS = {};
const SCORES = {
  // [paysage, budget, motif]
  norvege:   {nature:4, mer:1, safari:0, culture:1,  small:1, medium:3, large:2,  adventure:4, decouverte:3, nature2:4, detente:1},
  kenya:     {nature:2, mer:2, safari:5, culture:1,  small:0, medium:1, large:4,  adventure:3, decouverte:5, nature2:4, detente:1},
  balkans:   {nature:2, mer:4, safari:0, culture:4,  small:3, medium:4, large:2,  adventure:2, decouverte:4, nature2:2, detente:3},
  armenie:   {nature:3, mer:0, safari:0, culture:5,  small:5, medium:2, large:0,  adventure:2, decouverte:5, nature2:2, detente:1},
  costarica: {nature:3, mer:4, safari:2, culture:1,  small:1, medium:4, large:3,  adventure:5, decouverte:3, nature2:5, detente:2},
  srilanka:  {nature:2, mer:4, safari:2, culture:3,  small:3, medium:5, large:2,  adventure:3, decouverte:4, nature2:3, detente:3},
  japon:     {nature:2, mer:1, safari:0, culture:5,  small:1, medium:3, large:4,  adventure:2, decouverte:5, nature2:2, detente:2},
  colombie:  {nature:3, mer:2, safari:1, culture:4,  small:2, medium:4, large:2,  adventure:4, decouverte:4, nature2:3, detente:2},
  afrique:   {nature:2, mer:3, safari:4, culture:2,  small:0, medium:2, large:5,  adventure:3, decouverte:4, nature2:4, detente:3},
  tahiti:    {nature:1, mer:5, safari:0, culture:1,  small:0, medium:1, large:5,  adventure:2, decouverte:3, nature2:2, detente:5}
};
const MEDALS = ['🥇','🥈','🥉'];

document.querySelectorAll('.qz-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    const step = +this.dataset.step;
    const val = this.dataset.val;
    QUIZ_ANSWERS[step] = val;
    // Highlight selected
    document.querySelectorAll(`[data-step="${step}"]`).forEach(b => b.classList.remove('selected'));
    this.classList.add('selected');
    // Mark dot
    document.getElementById('dot' + step).classList.add('done');
    // Next step
    setTimeout(() => {
      document.getElementById('step' + step).classList.remove('active');
      if(step < 2) {
        document.getElementById('step' + (step+1)).classList.add('active');
      } else {
        quizShowResults();
      }
    }, 300);
  });
});

function quizShowResults() {
  const [q1, q2, q3] = [QUIZ_ANSWERS[0], QUIZ_ANSWERS[1], QUIZ_ANSWERS[2]];
  const scored = DESTS.map(d => {
    const s = SCORES[d.id] || {};
    const total = (s[q1]||0)*3 + (s[q2]||0)*2 + (s[q3]||0)*2;
    const max = 5*3 + 5*2 + 5*2;
    return {d, pct: Math.round(total/max*100)};
  }).sort((a,b) => b.pct - a.pct).slice(0,3);

  const top3 = document.getElementById('qzTop3');
  top3.innerHTML = scored.map((item, i) => `
    <div class="qz-dest" onclick="openModal('${item.d.id}')">
      <div class="qz-rank">${MEDALS[i]}</div>
      <div class="qz-info">
        <strong>${item.d.flag} ${item.d.name}</strong>
        <span>${item.d.sub}</span>
      </div>
      <div class="qz-pct">${item.pct}%</div>
    </div>
  `).join('');

  document.querySelectorAll('.qz-step').forEach(s => s.classList.remove('active'));
  document.getElementById('qzResults').style.display = 'block';
  document.getElementById('quizWrap').querySelector('.qz-progress').style.opacity = '0';
}

function quizReset() {
  Object.keys(QUIZ_ANSWERS).forEach(k => delete QUIZ_ANSWERS[k]);
  document.getElementById('qzResults').style.display = 'none';
  document.getElementById('quizWrap').querySelector('.qz-progress').style.opacity = '1';
  document.querySelectorAll('.qz-dot').forEach(d => d.classList.remove('done'));
  document.querySelectorAll('.qz-btn').forEach(b => b.classList.remove('selected'));
  document.querySelectorAll('.qz-step').forEach(s => s.classList.remove('active'));
  document.getElementById('step0').classList.add('active');
}

