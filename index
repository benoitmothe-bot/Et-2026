<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Les Vacances de Mar et Ben ✈️</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,500;0,700;1,300;1,500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
:root{
  --bg:#f5f3ef;--card:#fff;--dark:#1a1a2e;--slate:#5a6a7a;
  --teal:#0d9488;--teal2:#14b8a6;--gold:#c8943a;--white:#fff;
  --border:#e8e0d5;--shadow:0 4px 24px rgba(0,0,0,.09);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--dark);overflow-x:hidden}
img{display:block;width:100%;object-fit:cover}
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:#f0ede8}
::-webkit-scrollbar-thumb{background:var(--teal);border-radius:3px}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:500;display:flex;align-items:center;
  justify-content:space-between;padding:.8rem 2.5rem;
  background:rgba(245,243,239,.93);backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border)}
.nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:500;
  color:var(--dark);display:flex;align-items:center;gap:.5rem}
.nav-logo span{color:var(--teal)}
nav ul{display:flex;gap:1.5rem;list-style:none}
nav a{font-size:.72rem;letter-spacing:.09em;text-transform:uppercase;color:var(--slate);
  transition:color .2s;font-weight:500;text-decoration:none}
nav a:hover{color:var(--teal)}

/* HERO */
.hero{height:100vh;position:relative;display:flex;align-items:flex-end;overflow:hidden}
.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center;
  animation:hzoom 25s ease-in-out infinite alternate}
@keyframes hzoom{from{transform:scale(1.03)}to{transform:scale(1.09)}}
.hero-ov{position:absolute;inset:0;
  background:linear-gradient(to top,rgba(26,26,46,.95) 0%,rgba(26,26,46,.5) 50%,rgba(26,26,46,.1) 100%)}
.hero-body{position:relative;z-index:2;padding:5rem 3rem;width:100%;max-width:1300px;display:flex;align-items:flex-end;gap:3rem;flex-wrap:wrap}
.hero-chip{display:inline-block;background:var(--teal);color:#fff;font-size:.68rem;
  font-weight:600;letter-spacing:.16em;text-transform:uppercase;padding:.3rem .9rem;margin-bottom:1.5rem}
.hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(3.5rem,8vw,6.5rem);
  font-weight:300;line-height:.93;color:#fff;margin-bottom:1.2rem}
.hero h1 em{font-style:italic;color:var(--teal2)}
.hero-sub{font-size:1rem;color:rgba(255,255,255,.65);max-width:480px;line-height:1.7;margin-bottom:2rem}
.hero-pills{display:flex;flex-wrap:wrap;gap:.6rem}
.hpill{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);
  color:rgba(255,255,255,.7);font-size:.75rem;padding:.3rem .8rem}
.scroll-hint{position:absolute;bottom:2rem;right:3rem;z-index:2;
  display:flex;flex-direction:column;align-items:center;gap:.4rem;
  color:rgba(255,255,255,.35);font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;
  animation:sbounce 2s ease-in-out infinite}
.scroll-hint::after{content:'';width:1px;height:38px;
  background:linear-gradient(rgba(255,255,255,.35),transparent)}
@keyframes sbounce{0%,100%{transform:translateY(0)}50%{transform:translateY(5px)}}

/* PROFILES */
.profiles-section{background:var(--dark);padding:4.5rem 3rem}
.profiles-inner{max-width:1100px;margin:0 auto;display:grid;
  grid-template-columns:1fr 1fr;gap:3rem;align-items:start}
.profiles-inner h2{font-family:'Cormorant Garamond',serif;
  font-size:clamp(1.8rem,3.5vw,3rem);font-weight:300;color:#fff;line-height:1.1}
.profiles-inner h2 strong{font-weight:600;color:var(--teal2)}
.profiles-inner p{margin-top:.8rem;color:rgba(255,255,255,.45);font-size:.88rem;line-height:1.65}
.profile-cards{display:flex;flex-direction:column;gap:.8rem;margin-top:.3rem}
.pcard{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.09);
  padding:1rem 1.3rem;border-left:3px solid var(--teal)}
.pcard h4{font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:var(--teal2);margin-bottom:.35rem}
.pcard p{font-size:.85rem;color:rgba(255,255,255,.62);line-height:1.5}
.conv-bar{background:rgba(13,148,136,.1);border:1px solid rgba(13,148,136,.25);
  padding:.8rem 1.1rem;font-size:.82rem;color:var(--teal2);line-height:1.55}
.excl-bar{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);
  padding:.65rem 1.1rem;font-size:.75rem;color:rgba(255,255,255,.3);margin-top:.6rem}

/* FILTER */
.filter-section{padding:3rem 3rem 1.5rem;max-width:1200px;margin:0 auto}
.filter-section h2{font-family:'Cormorant Garamond',serif;font-size:2rem;
  font-weight:500;color:var(--dark);margin-bottom:1.5rem}
.filter-tabs{display:flex;flex-wrap:wrap;gap:.5rem}
.ftab{background:var(--card);border:1.5px solid var(--border);padding:.45rem 1.1rem;
  font-size:.78rem;font-weight:500;letter-spacing:.04em;cursor:pointer;
  transition:all .2s;color:var(--slate)}
.ftab:hover{border-color:var(--teal);color:var(--teal)}
.ftab.active{background:var(--teal);border-color:var(--teal);color:#fff}
.ftab .cnt{background:rgba(255,255,255,.25);padding:0 .35rem;
  font-size:.7rem;margin-left:.3rem;border-radius:2px}
.ftab:not(.active) .cnt{background:var(--border);color:var(--slate)}

/* CARDS GRID */
.cards-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;
  padding:1.5rem 3rem 4rem;max-width:1200px;margin:0 auto}
.dest-card{background:var(--card);overflow:hidden;cursor:pointer;
  box-shadow:var(--shadow);transition:transform .3s,box-shadow .3s;position:relative}
.dest-card:hover{transform:translateY(-5px);box-shadow:0 12px 40px rgba(0,0,0,.14)}
.dest-card.hidden{display:none}
.card-photo{height:220px;overflow:hidden;position:relative}
.card-photo img{height:100%;transition:transform .6s ease}
.dest-card:hover .card-photo img{transform:scale(1.06)}
.card-photo-ov{position:absolute;inset:0;
  background:linear-gradient(to top,rgba(0,0,0,.55) 0%,transparent 60%)}
.card-num{position:absolute;top:.8rem;left:.8rem;width:30px;height:30px;
  display:flex;align-items:center;justify-content:center;
  font-size:.65rem;font-weight:700;color:#fff}
.card-badges{position:absolute;top:.7rem;right:.7rem;
  display:flex;flex-direction:column;align-items:flex-end;gap:.3rem}
.badge-visited{background:rgba(30,41,59,.85);color:rgba(255,255,255,.7);
  font-size:.6rem;letter-spacing:.08em;padding:.2rem .55rem;text-transform:uppercase}
.badge-marion{background:rgba(239,68,68,.8);color:#fff;
  font-size:.6rem;letter-spacing:.08em;padding:.2rem .55rem;text-transform:uppercase}
.card-flag{position:absolute;bottom:.7rem;left:.8rem;font-size:1.5rem;line-height:1}
.card-body{padding:1.1rem 1.2rem 1.3rem}
.card-body h3{font-family:'Cormorant Garamond',serif;font-size:1.35rem;
  font-weight:600;color:var(--dark);margin-bottom:.1rem}
.card-sub{font-size:.8rem;color:var(--slate);margin-bottom:.75rem}
.card-budget{display:inline-flex;align-items:center;gap:.35rem;
  font-size:.78rem;font-weight:600;padding:.3rem .75rem;margin-bottom:.8rem}
.card-tagline{font-size:.82rem;color:var(--slate);line-height:1.5;margin-bottom:.9rem}
.card-tags{display:flex;flex-wrap:wrap;gap:.3rem}
.ctag{font-size:.68rem;border:1px solid;padding:.2rem .55rem;letter-spacing:.03em}
.card-cta{width:100%;background:var(--dark);color:#fff;border:none;padding:.7rem;
  font-family:'Outfit',sans-serif;font-size:.78rem;font-weight:500;
  letter-spacing:.08em;text-transform:uppercase;cursor:pointer;margin-top:1rem;
  transition:background .2s;display:flex;align-items:center;justify-content:center;gap:.5rem}
.card-cta:hover{background:var(--teal)}

/* MODAL */
.modal-bg{display:none;position:fixed;inset:0;z-index:800;
  background:rgba(20,20,35,.6);backdrop-filter:blur(5px)}
.modal-bg.open{display:flex;align-items:flex-start;justify-content:center;
  overflow-y:auto;padding:1.5rem}
.modal{background:var(--bg);width:100%;max-width:1050px;
  margin:auto;position:relative;animation:mslide .35s ease}
@keyframes mslide{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}
.modal-close{position:absolute;top:1rem;right:1rem;z-index:10;width:36px;height:36px;
  background:rgba(0,0,0,.5);border:none;cursor:pointer;
  color:#fff;font-size:1rem;display:flex;align-items:center;justify-content:center}
.modal-hero{height:380px;overflow:hidden;position:relative}
.modal-hero img{height:100%}
.modal-hero-ov{position:absolute;inset:0;
  background:linear-gradient(to top,rgba(26,26,46,.85) 0%,transparent 60%)}
.modal-hero-body{position:absolute;bottom:0;left:0;right:0;padding:2rem}
.modal-hero-body h2{font-family:'Cormorant Garamond',serif;font-size:2.8rem;
  font-weight:300;color:#fff;line-height:.95}
.mhsub{font-size:.95rem;color:rgba(255,255,255,.7);margin-top:.4rem}
.modal-tags{display:flex;flex-wrap:wrap;gap:.4rem;padding:1rem 1.5rem;background:var(--dark)}
.mtag{font-size:.72rem;border:1px solid rgba(255,255,255,.2);
  color:rgba(255,255,255,.75);padding:.22rem .65rem}
.modal-cols{display:grid;grid-template-columns:1.1fr .9fr;border-top:3px solid}
.modal-left{padding:2rem 1.8rem;border-right:1px solid var(--border)}
.modal-right{padding:2rem 1.8rem}
.modal-left h3,.modal-right h3{font-family:'Cormorant Garamond',serif;
  font-size:1.4rem;font-weight:600;color:var(--dark);margin-bottom:1.3rem}
.mweek{display:grid;grid-template-columns:46px 1fr;gap:.8rem;
  margin-bottom:1.1rem;padding-bottom:1.1rem;border-bottom:1px solid var(--border)}
.mweek:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
.mwbadge{width:42px;height:42px;display:flex;align-items:center;justify-content:center;
  font-size:.58rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;
  color:#fff;flex-shrink:0}
.mwbody h4{font-size:.88rem;font-weight:600;color:var(--dark);margin-bottom:.2rem}
.mwbody p{font-size:.8rem;color:var(--slate);line-height:1.5}
.micard{background:var(--card);padding:1rem 1.2rem;margin-bottom:.75rem;
  box-shadow:0 1px 3px rgba(0,0,0,.06);border-left:3px solid}
.micard h5{font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;
  font-weight:700;margin-bottom:.4rem}
.micard p{font-size:.8rem;color:var(--slate);line-height:1.55}
.modal-map-wrap{background:var(--card);border-top:1px solid var(--border)}
.modal-map-header{padding:.9rem 1.5rem;display:flex;align-items:center;
  justify-content:space-between;border-bottom:1px solid var(--border)}
.modal-map-header h4{font-family:'Cormorant Garamond',serif;
  font-size:1.1rem;font-weight:600;color:var(--dark)}
.mmap-legend{display:flex;gap:.8rem;flex-wrap:wrap}
.leg{display:flex;align-items:center;gap:.3rem;font-size:.72rem;color:var(--slate)}
.leg-dot{width:10px;height:10px;border-radius:50%}
.mmap{height:380px;width:100%}
.modal-gallery{display:grid;grid-template-columns:repeat(3,1fr);height:180px;overflow:hidden}
.modal-gallery img{height:100%;filter:brightness(.88);
  transition:filter .4s,transform .5s}
.modal-gallery img:hover{filter:brightness(1);transform:scale(1.04)}

/* TAHITI */
.tahiti-section{background:linear-gradient(135deg,#0c2e3a 0%,#0a4a5c 40%,#0c3040 100%);
  padding:6rem 3rem;position:relative;overflow:hidden}
.tahiti-section::before{content:'';position:absolute;top:-100px;right:-100px;
  width:500px;height:500px;border-radius:50%;
  background:radial-gradient(circle,rgba(200,148,58,.12),transparent 70%)}
.tahiti-inner{max-width:1200px;margin:0 auto}
.tahiti-header{text-align:center;margin-bottom:4rem}
.tahiti-eyebrow{display:inline-flex;align-items:center;gap:.5rem;
  background:rgba(200,148,58,.15);border:1px solid rgba(200,148,58,.4);
  color:var(--gold);font-size:.7rem;letter-spacing:.18em;text-transform:uppercase;
  padding:.4rem 1.1rem;margin-bottom:1.5rem;font-weight:600}
.tahiti-header h2{font-family:'Cormorant Garamond',serif;
  font-size:clamp(2.5rem,5vw,4.5rem);font-weight:300;color:#fff;line-height:.95}
.tahiti-header h2 em{font-style:italic;color:var(--gold)}
.tahiti-header p{font-size:1rem;color:rgba(255,255,255,.55);
  max-width:600px;margin:1.2rem auto 0;line-height:1.75}
.tahiti-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:2.5rem;align-items:start}
.tahiti-left h3,.tahiti-right h3{font-family:'Cormorant Garamond',serif;
  font-size:1.5rem;font-weight:500;color:#fff;margin-bottom:1.3rem}
.tphoto-hero{height:280px;overflow:hidden;margin-bottom:.7rem;position:relative}
.tphoto-hero img{height:100%;transition:transform .7s}
.tphoto-hero:hover img{transform:scale(1.04)}
.tgallery{display:grid;grid-template-columns:1fr 1fr;gap:.55rem}
.tgallery div{height:140px;overflow:hidden}
.tgallery img{height:100%;filter:brightness(.85);transition:transform .5s,filter .4s}
.tgallery div:hover img{transform:scale(1.04);filter:brightness(1)}
.tahiti-map-wrap{margin-top:2rem}
.tmap{height:360px;width:100%;margin-top:.6rem}
.tahiti-tags{display:flex;flex-wrap:wrap;gap:.4rem;margin:1.2rem 0}
.ttag{border:1px solid rgba(200,148,58,.4);color:rgba(200,148,58,.9);
  font-size:.72rem;padding:.25rem .7rem;letter-spacing:.04em}
.tahiti-budget{display:inline-flex;align-items:center;gap:.5rem;
  background:rgba(200,148,58,.2);border:1px solid rgba(200,148,58,.5);
  color:var(--gold);font-size:.9rem;font-weight:600;padding:.5rem 1.2rem;margin-bottom:1.3rem}
.tweek{display:grid;grid-template-columns:44px 1fr;gap:.75rem;
  margin-bottom:1rem;padding-bottom:1rem;border-bottom:1px solid rgba(255,255,255,.08)}
.tweek:last-child{border-bottom:none}
.twbadge{width:40px;height:40px;background:rgba(200,148,58,.2);
  border:1px solid rgba(200,148,58,.4);display:flex;align-items:center;justify-content:center;
  font-size:.58rem;font-weight:700;color:var(--gold);text-transform:uppercase;flex-shrink:0}
.twbody h4{font-size:.88rem;font-weight:600;color:rgba(255,255,255,.9);margin-bottom:.18rem}
.twbody p{font-size:.8rem;color:rgba(255,255,255,.5);line-height:1.5}
.tcards{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin-top:1.3rem}
.tcard{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);padding:.9rem 1rem}
.tcard h5{font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;
  color:rgba(200,148,58,.8);margin-bottom:.35rem}
.tcard p{font-size:.8rem;color:rgba(255,255,255,.55);line-height:1.5}
.tahiti-note{background:rgba(200,148,58,.08);border:1px solid rgba(200,148,58,.2);
  padding:1.2rem 1.5rem;margin-top:1.5rem;font-size:.85rem;
  color:rgba(255,255,255,.55);line-height:1.65}
.tahiti-note strong{color:rgba(200,148,58,.9)}

/* FOOTER */
footer{background:var(--dark);padding:2rem 3rem;display:flex;align-items:center;
  justify-content:space-between;flex-wrap:wrap;gap:1rem;border-top:3px solid var(--teal)}
footer .fl{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--teal2)}
footer .fm{font-size:.78rem;color:rgba(255,255,255,.35);text-align:center}
footer .fr{font-size:.72rem;color:rgba(255,255,255,.2)}

/* REVEAL */
.rv{opacity:0;transform:translateY(24px);transition:opacity .7s ease,transform .7s ease}
.rv.on{opacity:1;transform:none}
.rv.d1{transition-delay:.15s}.rv.d2{transition-delay:.3s}.rv.d3{transition-delay:.45s}

/* RESPONSIVE */
@media(max-width:900px){
  nav ul{display:none}
  .profiles-inner,.cards-grid,.tahiti-grid,.modal-cols,.tcards{grid-template-columns:1fr}
  .cards-grid,.filter-section,.hero-body,.profiles-section,.tahiti-section{padding-left:1.2rem;padding-right:1.2rem}
  .tgallery{grid-template-columns:1fr 1fr}
  .modal-gallery{grid-template-columns:1fr 1fr}
  .modal-gallery img:last-child{display:none}
}
@media(max-width:600px){
  .hero h1{font-size:3rem}
  .cards-grid{grid-template-columns:1fr}
}

/* GOLD CARD — Tahiti special */
.dest-card.gold-card{
  box-shadow:0 0 0 3px #c8943a, 0 8px 32px rgba(200,148,58,.25);
  position:relative;
}
.dest-card.gold-card::before{
  content:'✨ Voyage d\'Exception';
  position:absolute;top:-1px;left:50%;transform:translateX(-50%);
  background:linear-gradient(90deg,#b8860b,#ffd700,#b8860b);
  color:#1a1a2e;font-size:.62rem;font-weight:700;letter-spacing:.1em;
  padding:.25rem 1rem;white-space:nowrap;z-index:10;text-transform:uppercase;
}
.dest-card.gold-card:hover{
  box-shadow:0 0 0 3px #ffd700, 0 16px 48px rgba(200,148,58,.4);
}
.dest-card.gold-card .card-cta{
  background:linear-gradient(90deg,#b8860b,#c8943a);color:#fff;
}
.dest-card.gold-card .card-cta:hover{background:linear-gradient(90deg,#c8943a,#ffd700);color:#1a1a2e;}

/* COMMENTS SECTION */
.comments-section{background:#fff;padding:4rem 3rem;border-top:1px solid var(--border)}
.comments-inner{max-width:860px;margin:0 auto}
.comments-inner h2{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:500;
  color:var(--dark);margin-bottom:.5rem}
.comments-inner p{font-size:.88rem;color:var(--slate);line-height:1.6;margin-bottom:2rem}


/* COMMENT FORM */
.comments-section{background:#f7f5f0;padding:4rem 3rem;border-top:3px solid var(--teal)}
.comments-inner{max-width:720px;margin:0 auto}
.comments-inner h2{font-family:'Cormorant Garamond',serif;font-size:2rem;
  font-weight:500;color:var(--dark);margin-bottom:.5rem}
.comments-inner>p{font-size:.88rem;color:var(--slate);line-height:1.6;margin-bottom:2rem}
.comment-form{display:flex;flex-direction:column;gap:1.2rem}
.cf-row{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem}
.cf-field{display:flex;flex-direction:column;gap:.4rem}
.cf-field label{font-size:.75rem;font-weight:600;letter-spacing:.06em;
  text-transform:uppercase;color:var(--slate)}
.cf-field input,.cf-field select,.cf-field textarea{
  background:#fff;border:1.5px solid var(--border);padding:.7rem .9rem;
  font-family:'Outfit',sans-serif;font-size:.9rem;color:var(--dark);
  outline:none;transition:border-color .2s;resize:vertical}
.cf-field input:focus,.cf-field select:focus,.cf-field textarea:focus{
  border-color:var(--teal)}
.cf-btn{background:var(--dark);color:#fff;border:none;padding:.85rem 2rem;
  font-family:'Outfit',sans-serif;font-size:.85rem;font-weight:600;
  letter-spacing:.08em;text-transform:uppercase;cursor:pointer;
  align-self:flex-start;transition:background .2s}
.cf-btn:hover{background:var(--teal)}
.cf-success{display:none;background:#f0fdf4;border:1px solid #bbf7d0;
  color:#166534;padding:.8rem 1.1rem;font-size:.85rem}
@media(max-width:600px){.cf-row{grid-template-columns:1fr}}

/* ── QUIZ WIDGET ── */
.quiz-wrap{position:relative;z-index:3;margin-top:2rem;background:rgba(10,15,30,.75);
  backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.15);border-radius:16px;
  padding:1.5rem;max-width:440px;color:#fff}
.quiz-wrap h3{font-family:'Cormorant Garamond',serif;font-size:1.35rem;margin:0 0 .3rem;color:#fff}
.quiz-wrap p.qz-intro{font-size:.8rem;color:rgba(255,255,255,.55);margin:0 0 1.2rem}
.qz-step{display:none}.qz-step.active{display:block}
.qz-q{font-size:.9rem;font-weight:600;margin-bottom:.8rem;color:rgba(255,255,255,.9)}
.qz-options{display:flex;flex-direction:column;gap:.5rem}
.qz-btn{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);
  border-radius:8px;padding:.6rem 1rem;color:#fff;font-size:.85rem;cursor:pointer;
  text-align:left;transition:all .2s}
.qz-btn:hover,.qz-btn.selected{background:var(--teal);border-color:var(--teal);color:#fff}
.qz-progress{display:flex;gap:.4rem;margin-bottom:1.2rem}
.qz-dot{height:4px;flex:1;border-radius:2px;background:rgba(255,255,255,.2);transition:background .3s}
.qz-dot.done{background:var(--teal)}
.qz-results{display:none}
